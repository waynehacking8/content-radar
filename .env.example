# Copy to `.env` (git-ignored) and fill in. Free sources need no keys.

# Knowledge base (vector search) — Qdrant Cloud free tier (https://cloud.qdrant.io).
# Embeddings run locally via fastembed (no key). Without these the bot falls back
# to the local SQLite full-text index.
QDRANT_URL=
QDRANT_API_KEY=

# Telegram chat bot — DM your radar and get grounded answers (content_radar.telegram_bot).
# Create a bot via @BotFather to get the token; lock it to your chat id(s).
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_CHAT_IDS=

# Synthesis runs on the local `claude` CLI (your subscription) by default — no
# key needed locally if you're logged into Claude Code.
#
# For automated/CI runs (GitHub Actions, laptop off): generate a 1-year
# subscription token with `claude setup-token` and store it as the
# CLAUDE_CODE_OAUTH_TOKEN secret. Works on monthly Pro/Max — no annual plan.
#
# Optional: override the synthesis model (default: claude-sonnet-4-6 / "sonnet")
# SYNTH_MODEL=sonnet
#
# Optional: only if you choose `--backend api` (pay-per-token instead of subscription)
# ANTHROPIC_API_KEY=

# X / Twitter via twitterapi.io — OPTIONAL. Leave blank to skip X.
# Pay-as-you-go (~$0.15 / 1,000 tweets). Get a key at https://twitterapi.io
TWITTERAPI_IO_KEY=

# Reddit — OPTIONAL but recommended (anonymous JSON is blocked in 2026).
# Create a free "script" app at https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

# Gmail — OPTIONAL. Fold AI-news newsletters (AINews etc.) from your inbox into
# the digest. Uses a FREE Gmail App Password (not your login password, no paid API):
# https://myaccount.google.com/apppasswords  (requires 2-Step Verification on).
# Tune which newsletters via Interests.gmail_query in config.py.
GMAIL_USER=
GMAIL_APP_PASSWORD=

# Discord — OPTIONAL. Official Bot API only (self-bots get accounts banned).
# Create a bot at https://discord.com/developers, enable the MESSAGE CONTENT
# intent, invite it to your servers, and list channel IDs in config.py
# (Interests.discord_channels).
DISCORD_BOT_TOKEN=
